root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]

# ---- Microsoft C# conventions ----
# Based on the recommendations at
# https://learn.microsoft.com/dotnet/csharp/fundamentals/coding-style/coding-conventions

# Namespaces & usings: modern (file-scoped namespaces, usings outside).
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true

# Allman braces (open brace on its own line).
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# `this.` qualifier: omit unless required to disambiguate.
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Predefined types (`int` over `System.Int32`, `string` over `System.String`).
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# Modifier order (Microsoft canonical).
csharp_preferred_modifier_order = public, private, protected, internal, file, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, required, volatile, async:suggestion
dotnet_style_readonly_field = true:suggestion

# Pattern matching & null handling (modern C#).
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# Object / collection / tuple expressions.
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_simplified_interpolation = true:suggestion

# ---- Project-specific preferences ----
# Rider / ReSharper keys mirror (and sometimes override) the Roslyn rules.

# Braces required on every block. Formatter adds them on reformat.
csharp_prefer_braces = true:warning
dotnet_diagnostic.IDE0011.severity = warning
resharper_braces_for_ifelse = required
resharper_braces_for_for = required
resharper_braces_for_foreach = required
resharper_braces_for_while = required
resharper_braces_for_dowhile = required
resharper_braces_for_using = required
resharper_braces_for_lock = required
resharper_braces_for_fixed = required
resharper_braces_redundant = false

# Attributes on their own line above the member.
resharper_place_attribute_on_same_line = never
resharper_csharp_place_attribute_on_same_line = never

# Target-typed new() when the type is obvious.
csharp_style_implicit_object_creation_when_type_is_apparent = true:warning
dotnet_diagnostic.IDE0090.severity = warning
resharper_csharp_style_implicit_object_creation_when_type_is_apparent = true
resharper_arrange_type_name_in_object_creation_highlighting = none
resharper_arrange_object_creation_when_type_evident_highlighting = none
resharper_arrange_object_creation_when_type_not_evident_highlighting = none

# Expression-bodied members: vanilla Microsoft defaults. Methods /
# constructors / operators / local functions prefer block body. Properties /
# accessors / indexers / lambdas prefer `=>`. Severities are `silent` so
# the formatter does not auto-rewrite either way; the hints show in the
# IDE but stay quiet. Long property bodies will fold to block via Rider's
# default `use_heuristics` behavior once they exceed `csharp_max_line_length`.
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_local_functions = false:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_lambdas = true:silent

# Remove unnecessary usings (build-enforced via GenerateDocumentationFile in Directory.Build.props).
dotnet_diagnostic.IDE0005.severity = warning

# Simple `using` statements and method-group conversions. Suggestion-level: Rider's Cleanup applies
# them and the IDE hints, but they don't add build noise.
csharp_prefer_simple_using_statement = true:suggestion
dotnet_diagnostic.IDE0063.severity = suggestion
csharp_style_prefer_method_group_conversion = true:suggestion
dotnet_diagnostic.IDE0200.severity = suggestion

# `var` vs explicit type: no opinion. Author's choice is preserved on save.
dotnet_diagnostic.IDE0007.severity = silent
dotnet_diagnostic.IDE0008.severity = silent
resharper_suggest_var_or_type_built_in_types_highlighting = none
resharper_suggest_var_or_type_simple_types_highlighting = none
resharper_suggest_var_or_type_elsewhere_highlighting = none

# No auto-wrap on widescreens. Respect the author's arrangement. Wrap only
# when a line genuinely exceeds 200 chars.
max_line_length = off
resharper_csharp_max_line_length = 200
resharper_wrap_parameters_style = wrap_if_long
resharper_wrap_arguments_style = wrap_if_long
resharper_wrap_chained_method_calls = wrap_if_long
resharper_wrap_before_declaration_lpar = false
resharper_wrap_before_invocation_lpar = false
resharper_keep_existing_declaration_parens_arrangement = true
resharper_keep_existing_invocation_parens_arrangement = true
resharper_keep_existing_initializer_arrangement = true
resharper_keep_existing_expr_member_arrangement = true
resharper_keep_existing_switch_expression_arrangement = true

# ---- Naming conventions ----
# Private fields: _camelCase. Constants: PascalCase.

dotnet_naming_rule.private_fields_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_with_underscore.style = underscore_camel_case
dotnet_naming_rule.private_fields_with_underscore.severity = suggestion
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

dotnet_naming_rule.constants_are_pascal_case.symbols = constants
dotnet_naming_rule.constants_are_pascal_case.style = pascal_case
dotnet_naming_rule.constants_are_pascal_case.severity = suggestion
dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.applicable_accessibilities = *
dotnet_naming_symbols.constants.required_modifiers = const
dotnet_naming_style.pascal_case.capitalization = pascal_case

# ---- Generated code ----
# EF Core migrations are generated (block namespaces, extra usings). Don't lint them.
[**/Migrations/*.cs]
generated_code = true
