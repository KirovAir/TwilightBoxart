<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="TwilightBoxart.Desktop.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <!-- FluentAvalonia gives the real Windows 11 / WinUI control look. Pinned to light with a fixed
             accent so it is consistent across OSes rather than borrowing whatever the machine is set to. -->
        <sty:FluentAvaloniaTheme PreferSystemTheme="False"
                                 PreferUserAccentColor="False"
                                 CustomAccentColor="#7566DD" />

        <!-- The classic app's group boxes: a bordered panel under a plain label. -->
        <Style Selector="Border.group">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DEDAF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <!-- Section labels and the counter captions, in the web client's muted ink. -->
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#746F9B" />
        </Style>
        <Style Selector="TextBlock.counter">
            <Setter Property="Foreground" Value="#746F9B" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="BorderBrush" Value="#DEDAF0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Application.Styles>
</Application>
